{
  "name": "@clipbus/aira2-plugin",
  "private": true,
  "version": "2.0.0",
  "description": "Clipbus plugin that detects download links and submits them to aria2 RPC.",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite --host 127.0.0.1 --open /src/features/aria2-download/index.html",
    "dev:renderer": "vite --host 127.0.0.1 --open /src/features/aria2-download/index.html",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:runtime": "node ./scripts/build-runtime.mjs",
    "build:ui": "node ./scripts/build-ui.mjs",
    "verify:build": "node ./scripts/verify-build.mjs",
    "build:artifacts": "npm run clean && npm run build:runtime && npm run build:ui && npm run verify:build",
    "build": "npm run typecheck && npm run build:artifacts",
    "verify": "npm run build && npm test",
    "test": "node --test ./tests/**/*.test.cjs"
  },
  "dependencies": {
    "@clipbus/plugin-sdk": "^0.7.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "vite": "^5.4.14",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.12"
  }
}
